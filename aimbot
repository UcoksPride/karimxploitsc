-- --- ESP LOGIC ---
local function CreateESP(player)
    if player == LocalPlayer then return end
    if ESPObjects[player] then return end
    
    local objects = {
        Box = Drawing.new("Square"),
        HealthBar = Drawing.new("Square"),
        Distance = Drawing.new("Text"),
        Snapline = Drawing.new("Line")
    }
    
    for _, obj in pairs(objects) do
        obj.Visible = false
        if obj.Type == "Square" then
            obj.Thickness = 2
            obj.Filled = false
        end
    end
    
    objects.Box.Color = Settings.ESP.BoxColor
    objects.Snapline.Color = Settings.ESP.BoxColor
    objects.Distance.Center = true
    objects.Distance.Size = 16
    objects.Distance.Color = Settings.ESP.DistanceColor
    
    ESPObjects[player] = objects
end

local function RemoveESP(player)
    if ESPObjects[player] then
        for _, obj in pairs(ESPObjects[player]) do
            obj:Remove()
        end
        ESPObjects[player] = nil
    end
end

local function UpdateESP(player, objects)
    if not Settings.ESP.Enabled or not player.Character then
        for _, obj in pairs(objects) do obj.Visible = false end
        return
    end
    
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    local head = player.Character:FindFirstChild("Head")
    local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or humanoid.Health <= 0 or not head or not rootPart then
        for _, obj in pairs(objects) do obj.Visible = false end
        return
    end
    
    local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
    if not onScreen then
        for _, obj in pairs(objects) do obj.Visible = false end
        return
    end
    
    local distance = (rootPart.Position - Camera.CFrame.Position).Magnitude
    local scale = 1000 / distance
    
    objects.Box.Size = Vector2.new(scale, scale * 1.5)
    objects.Box.Position = Vector2.new(pos.X - (scale / 2), pos.Y - (scale * 0.75))
    objects.Box.Visible = true
    
    local healthPercent = humanoid.Health / humanoid.MaxHealth
    objects.HealthBar.Size = Vector2.new(4, scale * 1.5 * healthPercent)
    objects.HealthBar.Position = Vector2.new(pos.X - (scale / 2) - 8, (pos.Y - (scale * 0.75)) + (scale * 1.5 * (1 - healthPercent)))
    objects.HealthBar.Color = healthPercent > 0.5 and Color3.new(0,1,0) or Color3.new(1,0,0)
    objects.HealthBar.Visible = true
    
    objects.Distance.Text = math.floor(distance) .. "m"
    objects.Distance.Position = Vector2.new(pos.X, pos.Y + (scale * 0.75) + 5)
    objects.Distance.Visible = true
    
    if Settings.ESP.SnaplineEnabled then
        objects.Snapline.From = Vector2.new(pos.X, pos.Y)
        local targetY = Settings.ESP.SnaplinePosition == "Bottom" and Camera.ViewportSize.Y or (Settings.ESP.SnaplinePosition == "Top" and 0 or Camera.ViewportSize.Y / 2)
        objects.Snapline.To = Vector2.new(Camera.ViewportSize.X / 2, targetY)
        objects.Snapline.Visible = true
    else
        objects.Snapline.Visible = false
    end
end

-- --- AIMBOT LOGIC ---
local function GetClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local maxFOV = Settings.Aimbot.FOV
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            if Settings.Aimbot.TeamCheck and player.Team == LocalPlayer.Team then
                continue
            end

            local targetPart = player.Character:FindFirstChild(Settings.Aimbot.TargetPart)
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            
            if targetPart and humanoid and humanoid.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local screenDist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    
                    if screenDist <= maxFOV and screenDist < shortestDistance then
                        local dist = (Camera.CFrame.Position - targetPart.Position).Magnitude
                        if dist <= Settings.Aimbot.MaxDistance then
                            shortestDistance = screenDist
                            closestPlayer = player
                        end
                    end
                end
            end
        end
    end
    return closestPlayer
end

